<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Message Mail Composer Form View -->
    <record id="view_message_mail_composer_form" model="ir.ui.view">
        <field name="name">message.mail.composer.form</field>
        <field name="model">message.mail.composer</field>
        <field name="arch" type="xml">
            <form string="Compose Mail">
                <sheet>
                    <group>
                        <group>
                            <field name="email_from" placeholder="sender@example.com"/>
                            <field name="email_to" placeholder="recipient@example.com"/>
                            <field name="email_cc" placeholder="cc@example.com"/>
                            <field name="subject" placeholder="Email Subject"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Body" name="body">
                            <field name="body" widget="html" placeholder="Write your message here..."/>
                        </page>
                        <page string="Attachments" name="attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button string="Send" type="object" name="action_send_mail" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the message mail composer -->
    <record id="action_custom_mail_composer" model="ir.actions.act_window">
        <field name="name">Compose Mail</field>
        <field name="res_model">message.mail.composer</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>