<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Inherit and modify mail.mail form view for Odoo 19 -->
    <record id="view_mail_mail_form_inherit" model="ir.ui.view">
        <field name="name">mail.mail.form.inherit</field>
        <field name="model">mail.mail</field>
        <field name="inherit_id" ref="mail.view_mail_form"/>
        <field name="arch" type="xml">
            <!-- Remove readonly from body_content-->
            <xpath expr="//field[@name='body_content']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
        </field>
    </record>
</odoo>