<odoo>

    <!-- list VIEW -->
    <record id="view_laundry_product_list" model="ir.ui.view">
        <field name="name">laundry.product.list</field>
        <field name="model">laundry.product</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="category"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_laundry_product_form" model="ir.ui.view">
        <field name="name">laundry.product.form</field>
        <field name="model">laundry.product</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                        <field name="active" invisible="1"/>
                        <field name="company_id" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_laundry_product" model="ir.actions.act_window">
        <field name="name">Laundry Products</field>
        <field name="res_model">laundry.product</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>