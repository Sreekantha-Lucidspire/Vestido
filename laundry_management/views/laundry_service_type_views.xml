<odoo>

    <!-- list -->
    <record id="view_laundry_service_type_list" model="ir.ui.view">
        <field name="name">laundry.service.type.list</field>
        <field name="model">laundry.service.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="hsn"/>
                <field name="income_account_id"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_laundry_service_type_form" model="ir.ui.view">
        <field name="name">laundry.service.type.form</field>
        <field name="model">laundry.service.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="hsn"/>
                        <field name="operation_type"/>
                        <field name="income_account_id"/>
                        <field name="company_id" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_laundry_service_type" model="ir.actions.act_window">
        <field name="name">Service Types</field>
        <field name="res_model">laundry.service.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>