<odoo>
    <record id="view_move_form_inherit_pickup_discount" model="ir.ui.view">
        <field name="name">account.move.form.inherit.pickup.discount</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Add inside invoice header section -->
            <xpath expr="//field[@name='ref']" position="after">
                <field name="laundry_order_id" options="{'no_open': True, 'no_edit':True, 'no_create': True}"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page name="extra_information" string="Extra Information">
                    <group string="Extra Information">
                        <field name="pickup_delivery"/>
                        <field name="invoice_discount"/>
                    </group>
                </page>

            </xpath>

        </field>
    </record>
</odoo>