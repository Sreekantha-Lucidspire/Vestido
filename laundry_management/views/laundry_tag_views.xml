<odoo>

    <!-- LIST VIEW -->
    <record id="view_laundry_tag_list" model="ir.ui.view">
        <field name="name">laundry.tag.list</field>
        <field name="model">laundry.tag</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="order_id"/>
                <field name="order_line_id"/>
                <field name="barcode"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_laundry_tag_form" model="ir.ui.view">
        <field name="name">laundry.tag.form</field>
        <field name="model">laundry.tag</field>
        <field name="arch" type="xml">
            <form string="Laundry Tag">

                <!-- HEADER (Correct place for actions) -->
                <header>
                    <button name="%(action_laundry_tag_report)d"
                            string="Print Tag"
                            type="action"
                            class="btn-primary"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="order_id"/>
                            <field name="order_line_id"/>
                        </group>

                        <group>
                            <field name="barcode" widget="barcode"/>
                            <field name="state"/>
                        </group>
                    </group>
                </sheet>

            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_laundry_tag" model="ir.actions.act_window">
        <field name="name">Laundry Tags</field>
        <field name="res_model">laundry.tag</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>