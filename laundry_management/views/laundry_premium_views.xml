<odoo>

    <record id="view_laundry_premium_list" model="ir.ui.view">
        <field name="name">laundry.premium.list</field>
        <field name="model">laundry.premium</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="multiplier"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_laundry_premium_form" model="ir.ui.view">
        <field name="name">laundry.premium.form</field>
        <field name="model">laundry.premium</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="multiplier"/>
                        <field name="active"/>
                        <field name="sequence" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_laundry_premium" model="ir.actions.act_window">
        <field name="name">Premium Pricing</field>
        <field name="res_model">laundry.premium</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>