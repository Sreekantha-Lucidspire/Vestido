<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================
        ACTION
    ========================== -->
    <record id="action_laundry_dashboard" model="ir.actions.act_window">
        <field name="name">Laundry Dashboard</field>
        <field name="res_model">laundry.dashboard</field>
        <field name="view_mode">kanban,list</field>
        <field name="target">current</field>
    </record>


    <!-- =========================
        MENU
    ========================== -->
    


    <!-- =========================
        LIST VIEW (TABLE)
    ========================== -->
    <record id="view_laundry_dashboard_list" model="ir.ui.view">
        <field name="name">laundry.dashboard.list</field>
        <field name="model">laundry.dashboard</field>
        <field name="arch" type="xml">
            <list create="0" delete="0">
                <field name="product_id"/>
                <field name="service_type"/>
                <field name="pending"/>
                <field name="progress"/>
                <field name="done"/>
            </list>
        </field>
    </record>


    <!-- =========================
        KANBAN VIEW (MAIN DASHBOARD)
    ========================== -->
    <record id="view_laundry_dashboard_kanban" model="ir.ui.view">
        <field name="name">laundry.dashboard.kanban</field>
        <field name="model">laundry.dashboard</field>
        <field name="arch" type="xml">

            <kanban create="0" edit="0">
                <field name="product_id"/>
                <field name="service_type"/>
                <field name="pending"/>
                <field name="progress"/>
                <field name="done"/>

                <templates>
                    <t t-name="card">
                        <div class="o_kanban_card p-3">

                            <!-- PRODUCT -->
                            <div class="fw-bold text-center mb-1">
                                <field name="product_id"/>
                            </div>

                            <!-- SERVICE -->
                            <div class="text-center text-muted small mb-2">
                                <field name="service_type"/>
                            </div>

                            <!-- STATS -->
                            <div class="row text-center">

                                <div class="col-4">
                                    <div class="text-muted small">Pending</div>
                                    <div class="fw-bold text-danger">
                                        <field name="pending"/>
                                    </div>
                                </div>

                                <div class="col-4">
                                    <div class="text-muted small">Progress</div>
                                    <div class="fw-bold text-warning">
                                        <field name="progress"/>
                                    </div>
                                </div>

                                <div class="col-4">
                                    <div class="text-muted small">Done</div>
                                    <div class="fw-bold text-success">
                                        <field name="done"/>
                                    </div>
                                </div>

                            </div>

                        </div>
                    </t>
                </templates>

            </kanban>

        </field>
    </record>

    <record id="action_laundry_dashboard_server" model="ir.actions.server">
	    <field name="name">Laundry Dashboard</field>
	    <field name="model_id" ref="model_laundry_dashboard"/>
	    <field name="state">code</field>
	    <field name="code">
	action = env['laundry.dashboard'].action_open_dashboard()
	    </field>
	</record>
    

</odoo>