<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="report_invoice_laundry_bill">

        <t t-call="web.html_container">

            <style>
                @page {
                    size: 80mm auto;
                    margin: 0 !important;
                }

                html, body {
                    margin: 0 !important;
                    padding: 0 !important;
                    font-family: Arial, sans-serif !important;
                }

                * {
                    font-family: Arial, sans-serif !important;
                }
            </style>

            <t t-foreach="docs" t-as="o">

                <div style="width: 100%; font-size: 11px; line-height: 1.4; position:relative;">

                    <table style="width:100%; margin-bottom:10px;">
                        <div style="
                             position:absolute;
                             top:22%;
                             left:0;
                             width:100%;
                             text-align:center;
                        ">
                             <strong style="font-size:14px;">
                                 TAX INVOICE
                             </strong>
                        </div>
                        <tr>
                              <td style="width:30%; text-align:left; vertical-align:top; padding-top:0;">
                                <t t-if="o.company_id.logo">
                                    <img t-att-src="image_data_uri(o.company_id.logo)"
                                         style="height:120px; width:auto;"/>
                                </t>
                              </td>

                               <td style="width:70%; text-align:left; vertical-align:top; padding-left:10mm">

                                <div style="margin-top:5px;">

                                 <div style="font-size:14px; font-weight:bold; line-height:1.2;">
                                     <t t-esc="o.company_id.name"/>
                                 </div>          
                        <div style="font-size:9px; line-height:1.4;">
                                     <t t-esc="o.company_id.street or ''"/><br/>
                                     <t t-esc="o.company_id.street2 or ''"/><br/>
                                     <t t-esc="o.company_id.city or ''"/>
                                     <t t-if="o.company_id.zip"> - <t t-esc="o.company_id.zip"/></t><br/>
                                 </div>
                                 <div style="font-size:10px;">
                                     Ph: <t t-esc="o.company_id.phone or '-'"/>
                                 </div>
                                 <div style="font-size:10px;">
                                     GSTIN: <t t-esc="o.company_id.vat or '-'"/>
                                 </div>
                                </div>
                               </td>
                        </tr>
                    </table>
<hr style="border:1px dashed #000; margin-top:8%;"/>

<table style="width:100%; font-size:11px; margin-top:7%;">
    <tr>
        <td style="width:50%; vertical-align:top; font-size:9px; line-height:1.4;">
            <b>Customer Name:</b> <t t-esc="o.partner_id.name"/><br/>
            <b>Address:</b> <t t-esc="o.partner_id.street or ''"/><t t-esc="o.partner_id.street2 or ''"/><br/>
            <t t-esc="o.partner_id.city or ''"/>
            <t t-if="o.partner_id.zip"> - <t t-esc="o.partner_id.zip"/></t><br/>
            <b>Contact No:</b> <t t-esc="o.partner_id.phone or '-'"/>
        </td>

        <td style="width:50%; text-align:left; vertical-align:top; font-size:9px; line-height:1.4; padding-left:16px;">
            <b>Order No:</b> <t t-esc="o.name"/><br/>
            <b>Received Date:</b> <span t-field="o.laundry_order_id.order_date" t-options="{'format': 'dd-MM-yyyy'}"/><br/>
            <b>Delivery Date:</b> <span t-field="o.laundry_order_id.delivery_date" t-options="{'format': 'dd-MM-yyyy'}"/>
        </td>
    </tr>
</table>

                    <hr style="border:1px dashed #000; margin-top:8px;"/>

                    <table style="width:100%; border-collapse:collapse; font-size:11px;">
                        <thead>
                            <tr>
                               <th style="text-align:left; font-weight:bold; padding:3px; vertical-align:top !important; line-height: 1.2;">S.No.</th>
                               <th style="text-align:left; font-weight:bold; padding:3px; vertical-align:top !important; line-height: 1.2;">Items &amp; Services</th>
                               <th style="text-align:right; font-weight:bold; padding:3px; vertical-align:top !important; line-height: 1.2;">Qty</th>
                               <th style="text-align:right; font-weight:bold; padding:3px; vertical-align:top !important; line-height: 1.2;">
                                   Wt
                                   <div style="font-size:9px; color:#333;">(Kg)</div>
                               </th>
                               <th style="text-align:right; font-weight:bold; padding:3px; vertical-align:top !important; line-height: 1.2;">
                                   Unit Price
                                   <div style="font-size:9px; color:#333;">(Rs.)</div>
                               </th>
                               <th style="text-align:right; font-weight:bold; padding:3px; vertical-align:top !important; line-height: 1.2;">
                                   Amt
                                  <div style="font-size:9px; color:#333;">(Rs.)</div>
                               </th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="i" t-value="0"/>
                            <t t-set="manual_sum_total" t-value="0"/>
                            <tr t-foreach="o.laundry_order_id.order_line_ids" t-as="l" style="border-bottom:0.5px solid #eee;">
                                <t t-set="i" t-value="i + 1"/>
                                <td style="padding:3px; text-align:left;">
                                    <t t-esc="i"/>
                                </td>
                                <td style="padding:3px;">
                                    <div>
                                        <t t-esc="l.product_id.name"/>
                                    </div>

                                <div style="font-size:9px; color:#333;">
                                    <t t-esc="l.service_type_id.name"/>
                                    <t t-if="l.premium_id">
                                        <span> | </span>
                                             <t t-esc="l.premium_id.name"/> 
                                    </t>
                                </div>
                                </td>
                                <td style="padding:5px; text-align:right;">
                                    <t t-esc="l.qty"/>
                                </td>
                                <td style="padding:5px; text-align:right;">
                                    <t t-esc="l.weight or 0.0"/>
                                </td>
                                <td style="padding:3px; text-align:right;">
                                     <t t-esc="l.unit_price or 0.0"/>
                                </td>
                                <td style="padding:3px; text-align:right;">
                                    <t t-set="line_rounded" t-value="int(l.subtotal + 0.5) if l.subtotal else 0"/>
                                    <t t-set="manual_sum_total" t-value="manual_sum_total + line_rounded"/>
            
                                    <t t-esc="'%.1f' % line_rounded"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <hr style="border:1px dashed #000; margin-top:8px;"/>
<td style="width:40%; vertical-align:top;">
    <table style="width:100%; font-size:11px; margin-top:10px;">
        <tr>
            <td style="width:60%; vertical-align:top;">
                <div style="font-weight:bold; font-size:12px; margin-bottom:5px;">GST SUMMARY</div>
                
                <t t-set="final_total" t-value="manual_sum_total - round(o.laundry_order_id.discount, 0)"/>
                <t t-set="base_amount" t-value="round(final_total / 1.18)"/>
                <t t-set="gst_amount" t-value="round(final_total - base_amount)"/>
                <div>Subtotal (Taxable Value): <t t-esc="'%.1f' % base_amount"/></div>
                <div>CGST + SGST (18%): <t t-esc="'%.1f' % gst_amount"/></div>
            </td>

            <td style="width:40%; text-align:right; vertical-align:top;">
                <div><b>Total: <t t-esc="'%.1f' % manual_sum_total"/></b></div>
                <div><b>Discount: <t t-esc="'%.1f' % round(o.laundry_order_id.discount, 0)"/></b></div>   
                <div style="font-size:12px; font-weight:bold; margin-top:5px;">
                    GRAND TOTAL: <t t-esc="'%.1f' % final_total"/>
                </div>
            </td>
        </tr>
    </table>

    <div style="margin-top:8px; font-size:9px; line-height:1.4; word-wrap:break-word; white-space:normal;">
        <b>Amount Payable in Words:</b>
        <t t-esc="o.currency_id.amount_to_text(final_total).replace('And Zero Paise', '').replace(' and Zero Paise', '')"/> Only
    </div>
</td>
                <hr style="border:1px dashed #000; margin-top:8px;"/>

<table style="
    width:100%;
    margin-top:10px;
    font-size:10px;
    border-collapse:collapse;
">
    <tr>

        <td style="
            width:65%;
            vertical-align:top;
            padding-right:8px;
            line-height:1.6;
        ">

            <div style="
                font-weight:bold;
                margin-bottom:4px;
                font-size:11px;
            ">
                Payment Details
            </div>

            <div>
                <b>Bank:</b> HDFC Bank
            </div>

            <div>
                <b>Account No:</b> 50200119008704
            </div>

            <div>
                <b>IFSC:</b> HDFC0004033
            </div>

            <div>
                <b>Recipient:</b> VESTIDO FABWASH STUDIO
            </div>

        </td>

        <td style="
            width:35%;
            vertical-align:top;
            text-align:center;
        ">

    <t t-set="upi_attachment" t-value="o.env['ir.attachment'].sudo().search([('name', '=', 'upi_qr.png')], limit=1)"/>

    <t t-if="upi_attachment">
        <img t-att-src="image_data_uri(upi_attachment.datas)" 
             style="width:100px;height:100px;"/>
    </t>
    
    <t t-else="">
        <div style="font-size:8px; color:red; border:1px solid red; padding:5px;">
            QR Attachment Missing<br/>(Upload 'upi_qr.png')
        </div>
    </t>
</td>

    </tr>
</table>

<hr style="border:1px dashed #000; margin-top:8px;"/>

</div>

<div style="
    margin-top:8px;
    font-size:9px;
    line-height:1.4;
    padding:4px;
">

    <b>Remarks:</b>

    <div style="word-wrap:break-word; white-space:normal;">
        <t t-if="o.laundry_order_id.remarks">
            <t t-esc="o.laundry_order_id.remarks"/>
        </t>
        <t t-else="">
            -
        </t>
    </div>

</div>
 <hr style="border:1px dashed #000; margin-top:8px;"/>
<div style="
    margin-top:4px;
    text-align:center;
    font-style:normal;
    font-weight:normal;
    font-size:10px;
">
    Thank you for your patronage!
</div>

        </t>
    </t>
</template>
</odoo>