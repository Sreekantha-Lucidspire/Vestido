<odoo>

    <template id="report_laundry_tag">

        <t t-call="web.html_container">

            <style>
                @page {
                    margin: 0;
                }

                html, body, .page {
                    margin: 0 !important;
                    padding: 0 !important;
                    font-family: Arial, sans-serif !important;
                }

                * {
                    font-family: Arial, sans-serif !important;
                }
            </style>

            <t t-foreach="docs" t-as="tag">

                <div style="
                    width: 250px;
                    height: 150px;
                    border: 1px solid #000;
                    padding: 10px;
                    margin: 5px;
                    display: inline-block;
                ">

                    <div>
                        <strong>Order:</strong>
                        <span t-esc="tag.order_id.name"/>
                    </div>


                    <div>
                        <strong>Customer:</strong>
                        <span t-esc="tag.partner_id.name"/>
                    </div>

                    <t t-if="tag.order_line_id">
                        <div>
                            <strong>Item:</strong>
                            <span t-esc="tag.order_line_id.product_id.name"/>
                        </div>
                    </t>

                    <div style="text-align:center; margin-top:10px;">
                        <span t-field="tag.barcode"
                              t-options="{
                                  'widget': 'barcode',
                                  'barcode_type': 'Code128',
                                  'width': 200,
                                  'height': 60,
                                  'humanreadable': 1
                              }"/>
                    </div>

            

                </div>

            </t>
        </t>

    </template>

<!-- </odoo>

<odoo> -->
    <template id="report_laundry_tag_30mm">

        <t t-call="web.html_container">

            <style>
                @page {
                    size: 30mm 30mm;
                    margin: 0;
                }

                html, body {
                    margin: 0;
                    padding: 0;
                    font-family: Arial, sans-serif !important;
                }

                * {
                    font-family: Arial, sans-serif !important;
                }
            </style>

            <t t-foreach="docs" t-as="tag" t-index="i">

                <div style="
                    width:100%;
                    height:100%;
                    padding:2mm;
                    font-size:32px;
                    border:1px solid #000;
                    box-sizing:border-box;
                    overflow:hidden;
                ">

                    <!-- Order -->
                    <!-- <div style="font-weight:bold; font-size:32px;">
                        <t t-esc="tag.order_id.name"/>
                    </div> -->
                    <div style="font-weight:bold; font-size:32px;">
                        <t t-esc="tag.name"/> -
                        <t t-esc="tag.order_line_id.service_type_id.name"/>
                    </div>

                    <!-- Customer -->
                    <div style="
                        white-space:nowrap;
                        overflow:hidden;
                        text-overflow:ellipsis;font-size:24px;
                    ">
                        <t t-esc="tag.order_id.name"/> - <t t-esc="tag.partner_id.name"/>
                    </div>

                    <!-- Item -->
                    <t t-if="tag.order_line_id">
                        <div style="
                            white-space:nowrap;
                            overflow:hidden;
                            text-overflow:ellipsis;font-size:24px;
                        ">
                            <t t-esc="tag.order_line_id.product_id.name"/> - <t t-esc="tag.order_line_id.qty"/> Qty
                        </div>
                    </t>

                    <!-- Barcode -->
                    <div style="text-align:center; margin-top:2px;">
                        <span t-field="tag.barcode"
                              t-options="{
                                  'widget': 'barcode',
                                  'barcode_type': 'Code128',
                                  'width': 300,
                                  'height': 80,
                                  'quiet': 0
                              }"/>
                    </div>

                </div>

                <!-- PAGE BREAK ONLY BETWEEN TAGS -->
                <t t-if="i != len(docs) - 1">
                    <div style="page-break-after: always;"></div>
                </t>

            </t>

        </t>

    </template>
