<odoo>

    <record id="paperformat_laundry_receipt_80mm" model="report.paperformat">
        <field name="name">Laundry Receipt 80mm</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>

        <!-- Width = 80mm -->
        <field name="page_width">80</field>

        <!-- Height auto grows -->
        <field name="page_height">200</field>

        <field name="orientation">Portrait</field>

        <!-- No margins -->
        <field name="margin_top">2</field>
        <field name="margin_bottom">2</field>
        <field name="margin_left">2</field>
        <field name="margin_right">2</field>

        <field name="dpi">96</field>
    </record>

    <record id="paperformat_laundry_tag_30mm" model="report.paperformat">
        <field name="name">Laundry Tag 30mm</field>
        <field name="format">custom</field>
        <field name="page_width">30</field>
        <field name="page_height">50</field>
        <field name="margin_top">1</field>
        <field name="margin_bottom">1</field>
        <field name="margin_left">1</field>
        <field name="margin_right">1</field>
    </record>

    <record id="action_laundry_tag_report" model="ir.actions.report">
        <field name="name">Laundry Tags</field>
        <field name="model">laundry.tag</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">laundry_management.report_laundry_tag</field>
        <field name="report_file">laundry_management.report_laundry_tag</field>

        <!-- Important -->
        <field name="print_report_name">'Laundry Tags - %s' % (object.name)</field>

        <!-- Binding (IMPORTANT for button + menu integration) -->
        <field name="binding_model_id" ref="model_laundry_tag"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_laundry_tag_30mm" model="ir.actions.report">
        <field name="name">Tag</field>
        <field name="model">laundry.tag</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">laundry_management.report_laundry_tag_30mm</field>
        <field name="report_file">laundry_management.report_laundry_tag_30mm</field>
        <field name="paperformat_id" ref="laundry_management.paperformat_laundry_tag_30mm"/>
        <field name="binding_model_id" ref="model_laundry_tag"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_laundry_receipt_80mm" model="ir.actions.report">
        <field name="name">Order Receipt</field>
        <field name="model">laundry.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">laundry_management.report_laundry_receipt_80mm</field>
        <field name="report_file">laundry_management.report_laundry_receipt_80mm</field>
        <field name="paperformat_id" ref="laundry_management.paperformat_laundry_receipt_80mm"/>
        <field name="binding_model_id" ref="model_laundry_order"/>
        <field name="binding_type">report</field>
    </record>
    <record id="action_laundry_quotation" model="ir.actions.report">
        <field name="name">Proforma Invoice</field> 
        
        <field name="model">laundry.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">laundry_management.report_laundry_quotation</field>
        <field name="report_file">laundry_management.report_laundry_quotation</field>
        <field name="paperformat_id" ref="laundry_management.paperformat_laundry_receipt_80mm"/>

        <field name="print_report_name">'Proforma Invoice - %s' % (object.name)</field>
    </record>
    <record id="action_laundry_invoice_bill" model="ir.actions.report">
        <field name="name">Invoice</field>
        <field name="model">laundry.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">laundry_management.report_laundry_invoice_bill</field>
        <field name="report_file">laundry_management.report_laundry_invoice_bill</field>

        <field name="paperformat_id" ref="laundry_management.paperformat_laundry_receipt_80mm"/>

        <field name="print_report_name">'Invoice - %s' % (object.name)</field>
        
        <field name="binding_model_id" ref="model_laundry_order"/>
        <field name="binding_type">report</field>
    </record>
    <record id="action_laundry_quotation" model="ir.actions.report">
        <field name="name">Proforma Invoice - Ver2</field> 
        
        <field name="model">laundry.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">laundry_management.report_laundry_quotation</field>
        <field name="report_file">laundry_management.report_laundry_quotation</field>
        <field name="paperformat_id" ref="laundry_management.paperformat_laundry_receipt_80mm"/>

        <field name="print_report_name">'Proforma Invoice - %s' % (object.name)</field>
    </record>

    <record id="account.account_invoices" model="ir.actions.report">
        <field name="name">Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">laundry_management.report_invoice_laundry_bill</field>
        <field name="report_file">laundry_management.report_invoice_laundry_bill</field>
        <field name="paperformat_id" ref="laundry_management.paperformat_laundry_receipt_80mm"/>
        <field name="print_report_name">'Invoice - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_account_move"/>
        <field name="binding_type">report</field>
    </record>
  
</odoo>